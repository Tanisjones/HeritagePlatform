# Production environment for the Heritage Platform stack (docker-compose.prod.yml).
# Copy to .env.prod on the server and fill in real values. NEVER commit .env.prod.
#
#   cp .env.prod.example .env.prod   # then edit

# ---- Django ----
# Generate with:  python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_secret
# Hostname the edge nginx serves this app at, plus the internal service names.
ALLOWED_HOSTS=heritageplatform.ddns.net,localhost,127.0.0.1,frontend,backend
# The SPA and admin are reached over HTTPS at the public hostname.
CSRF_TRUSTED_ORIGINS=https://heritageplatform.ddns.net
CORS_ALLOWED_ORIGINS=https://heritageplatform.ddns.net

# ---- PostgreSQL + PostGIS ----
POSTGRES_DB=heritage_platform
POSTGRES_USER=heritage
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ---- Frontend build-time API base ----
# Same-origin relative path so the bundle works behind the edge nginx. Leave as-is.
VITE_API_BASE_URL=/api/v1

# ---- First-boot bootstrap (optional) ----
# Leave the superuser auto-creation OFF and create one by hand after first deploy
# (docker compose ... exec backend python manage.py createsuperuser). If you prefer
# unattended creation, set CREATE_SUPERUSER=true and fill the three fields below.
CREATE_SUPERUSER=false
DJANGO_SUPERUSER_EMAIL=admin@heritageplatform.ddns.net
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=CHANGE_ME_strong_admin_password

# Seed the bundled heritage dataset on first start (skips if data already exists).
# Set to true for the very first deploy if you want demo content, then back to false.
SEED_HERITAGE_DATA=false
# Force a full reseed (DANGEROUS: wipes the seeded tables). Keep false in prod.
SEED_HERITAGE_RESET=false
# Use dummy media instead of downloading remote media during the seed.
SEED_HERITAGE_SKIP_MEDIA_DOWNLOADS=false
# Extra demo seed (sample heritage items + routes). Keep false in prod.
SEED_DEMO_DATA=false

# ---- Outbound email (optional, E4) ----
# By default the containers use Django's console backend: notification emails
# are printed to the backend logs and NOT delivered. For real delivery point
# these at your SMTP provider (e.g. an SES/Mailgun/Brevo SMTP endpoint) and
# switch the backend. Leave commented to keep console output.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=apikey_or_username
# EMAIL_HOST_PASSWORD=CHANGE_ME_smtp_password
# DEFAULT_FROM_EMAIL=noreply@heritageplatform.ddns.net

# ---- AI provider (optional) ----
# To enable AI in production, set `provider: gemini` (and a Gemini `model:`) in
# backend/config/ai.yaml and put your Google AI Studio key here. Leave empty to
# keep AI off. NEVER commit the real key.
GEMINI_API_KEY=

# ---- gunicorn ----
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Optional: server-wide timezone (IANA name). Per-city timezones live on the
# City model and are display-only; this global setting drives aggregation
# buckets (e.g. AI-usage day grouping). Default: America/Guayaquil.
# DJANGO_TIME_ZONE=America/Guayaquil
